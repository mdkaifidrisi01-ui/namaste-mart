{
  "name": "ignou-project",
  "private": true,
  "version": "1.0.0",
  "type": "module",

  "scripts": {
    "client": "cd client && npm run dev",

    "server": "cd server && node server.js",

    "dev": "concurrently \"npm run server\" \"npm run client\"",

    "build": "npm install --prefix client && npm run build --prefix client",

    "start": "node server/server.js"
  },

  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.1.0",
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.19.2",
    "framer-motion": "^12.23.24",
    "mongodb": "^7.0.0",
    "mongoose": "^9.1.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },

  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.10",
    "vite": "^7.1.7"
  },

  "description": "IGNOU Project",
  "license": "ISC"
}